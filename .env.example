# ── 모드 플래그 ───────────────────────────────────────────────────
# true: Mock DB/Auth 사용 (개발/테스트)
# false: 실제 PostgreSQL + SSO 사용 (운영)
USE_MOCK_DB=true
USE_MOCK_AUTH=true

# ── PostgreSQL (USE_MOCK_DB=false 시 필요) ────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=chatbot_db
PG_USER=postgres
PG_PASSWORD=your_password_here

# ── LLM 엔드포인트 (OpenAI 호환 사내 서버) ───────────────────────
LLM_BASE_URL=http://your-llm-server:port/v1
LLM_API_KEY=your-api-key
LLM_DEFAULT_MODEL=gpt-4o
LLM_TIMEOUT=120

# LLM 기본 설정 (챗봇 JSON에서 model 미지정 시 사용)
LLM_DEFAULT_TEMPERATURE=0.3
LLM_DEFAULT_MAX_TOKENS=1024

# ── Ingestion 서버 ────────────────────────────────────────────────
# 실 서버: http://<ingestion-server-host>:5500
# 개발/테스트: http://localhost:8001 (mock_ingestion_server.py)
INGESTION_BASE_URL=http://localhost:8001
INGESTION_API_KEY=ingestion-server-secret-key

# ── SSL 검증 ──────────────────────────────────────────────────────
# 사내망: false, 외부 배포: true
SSL_VERIFY=false

# ── 서버 ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── 세션 보안 ─────────────────────────────────────────────────────
# 사내 SSO 사용 시 반드시 변경 (32바이트 이상의 랜덤 문자열)
SECRET_KEY=change-this-in-production-secret-key-32bytes-minimum

# ── SSO/OIDC (USE_MOCK_AUTH=false 시 필요) ─────────────────────────
# 사내 SSO 서버 정보
SSO_ISSUER=https://sso.company.com
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret
SSO_REDIRECT_URI=http://localhost:8080/auth/acs

# OIDC Endpoints (SSO_ISSUER/.well-known/openid-configuration 에서 자동 로드됨)
# 자동 Discovery 실패 시 아래 값들을 채워넣음
# SSO_AUTH_URL=https://sso.company.com/oauth2/authorize
# SSO_TOKEN_URL=https://sso.company.com/oauth2/token
# SSO_USERINFO_URL=https://sso.company.com/oauth2/userinfo
# SSO_LOGOUT_URL=https://sso.company.com/oauth2/logout

# 요청 Scope
SSO_SCOPES=openid email profile

# ── 위임(Delegation) 설정 ─────────────────────────────────────────
# Confidence 임계값 (0-100): 이 값 미만이면 하위 Agent로 위임
DEFAULT_DELEGATION_THRESHOLD=70

# 최대 위임 깊이: 체인에서 최대 몇 단계까지 위임할 수 있는지
MAX_DELEGATION_DEPTH=5

# 하이브리드 선택기 가중치: 키워드 매칭 점수에 적용할 가중치 (0-1)
# 임베딩 가중치는 (1 - HYBRID_KEYWORD_WEIGHT)로 자동 계산됨
HYBRID_KEYWORD_WEIGHT=0.4

# ── Circuit Breaker 설정 ──────────────────────────────────────────
# OPEN 상태로 전환될 연속 실패 횟수 임계값
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# HALF_OPEN으로 복구 시도까지 대기 시간(초)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0
