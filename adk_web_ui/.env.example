# ADK Web UI - Environment Configuration
# 이 파일을 .env로 복사하고 실제 값을 설정하세요

# ============================================
# Database Settings (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adk_chat
DB_USER=postgres
DB_PASSWORD=your_password_here

# ============================================
# Database Settings (SQLite - 개발용)
# ============================================
# PostgreSQL 대신 SQLite를 사용하려면 true로 설정
USE_SQLITE=false
SQLITE_PATH=adk_chat.db

# ============================================
# Knox ID Settings
# ============================================
# 기본 Knox ID (인증 실패시 사용)
DEFAULT_KNOX_ID=anonymous

# Knox ID 필수 여부
# true: X-Knox-Id 헤더 없으면 401 반환
# false: DEFAULT_KNOX_ID 사용
REQUIRE_KNOX_ID=true

# ============================================
# Admin Settings
# ============================================
# 관리자 Knox ID 목록 (쉼표로 구분)
# 예: ADMIN_KNOX_IDS=admin001,admin002,admin003
ADMIN_KNOX_IDS=

# ============================================
# App Settings
# ============================================
# 디버그 모드 (개발: true, 운영: false)
DEBUG=false

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 앱 이름
APP_NAME="ADK Web UI"
